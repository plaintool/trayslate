            Caption = 'Json Pointer: Use / for levels, keys for objects, numbers for indexes. Use * for all items, *#10 to join items by newline. Separate multiple segments with ;. Use ~ at the end of path to return raw JSON branch.'#13#10'Literal: Text in {…}. Special tag {#10} for newlines. Use {{regex}} to extract data directly into the text.'#13#10'Logic: If a Pointer in a segment is empty, the whole segment is skipped. If a segment has no Pointer, it uses the full JSON as context.'#13#10'Regex: {prefix {regex} suffix} inside a block. If the regex finds no match, the entire {…} block is removed.'#13#10'Inversion: Start a segment with ! (e.g. !/path{Error}) to show its text ONLY if the Pointer data is missing or JSON is invalid.'#13#10'Examples:'#13#10'responseData/translatedText; matches/*#10/translation; /texts/text; {literal text#10}; /result/text; /text{ ({(\w+)})}; !/translations{Error: No data!#10}; /translations/0/text'
            Color = clInfoBk
            ParentColor = False
            Transparent = False
            WordWrap = True
          end
          object MemoJsonPointer: TMemo
            Left = 5
            Height = 256
            Top = 200
            Width = 543
            Align = alClient
            BorderSpacing.Top = 10
            BorderSpacing.Right = 15
            BorderSpacing.Around = 5
            ScrollBars = ssVertical
            TabOrder = 0
            WantReturns = False
            OnChange = ValueChange
          end
        end
      end
    end
