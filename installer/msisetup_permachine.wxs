<?xml version="1.0" encoding="utf-8"?>
<!--
    # This comment is generated by WixEdit, the specific commandline
    # arguments for the WiX Toolset are stored here.

    candleArgs: 
    lightArgs: "<projectname>.wixobj" -out "trayslator-allusers.msi" <extensions>
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
	<?define ProductVersion = "$(var.Version)" ?>
	<?define OpenSslDir = ".\redist" ?>
    <?if $(var.Platform) = x64 ?>
        <?define ProductName = "Trayslator $(var.ProductVersion)" ?>
        <?define Win64Value = "yes" ?>
        <?define ProgramFilesFolderVar = "ProgramFiles64Folder" ?>
		<?define ExeName = "trayslator.exe" ?>
		<?define ExeNameUpper = "TRAYSLATOR.EXE" ?>
        <?define SystemFolder = "System64Folder" ?>
		<?define LibCryptoName = "libcrypto-1_1-x64.dll" ?>
		<?define LibSslName    = "libssl-1_1-x64.dll" ?>
    <?else?>
        <?define ProductName = "Trayslator $(var.ProductVersion) (32-bit)" ?>
        <?define Win64Value = "no" ?>
        <?define ProgramFilesFolderVar = "ProgramFilesFolder" ?>
		<?define ExeName = "trayslator32.exe" ?>
		<?define ExeNameUpper = "TRAYSLATOR32.EXE" ?>
        <?define SystemFolder = "SystemFolder" ?>
		<?define LibCryptoName = "libcrypto-1_1.dll" ?>
		<?define LibSslName    = "libssl-1_1.dll" ?>
    <?endif?>
    
    <Product Id="*" Name="$(var.ProductName)" Language="1033" Version="$(var.ProductVersion)" Manufacturer="Alexander Tverskoy" UpgradeCode="45C75BC5-3DDC-453B-A7AB-7E2AE0D88699">
        <Package Description="$(var.ProductName)" Comments="Trayslator" Platform="$(var.Platform)" InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
        <!-- <Property Id="ALLUSERS" Value="1"/> -->
        <Property Id="MSIFASTINSTALL" Value="1" />
        <Property Id="ARPPRODUCTICON" Value="AppIcon" />
        <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />
        <Media Id="1" Cabinet="simple.cab" EmbedCab="yes" />
        <Upgrade Id="45C75BC5-3DDC-453B-A7AB-7E2AE0D88699">
            <UpgradeVersion Minimum="0.0.0" IncludeMinimum="yes" Maximum="$(var.ProductVersion)" IncludeMaximum="yes" Property="PREVIOUSFOUND" />
        </Upgrade>
        <InstallExecuteSequence>
            <RemoveExistingProducts After="InstallInitialize" />
        </InstallExecuteSequence>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <!-- <Directory Id="LocalAppDataFolder"> -->
            <Directory Id="$(var.ProgramFilesFolderVar)">
                <Directory Id="INSTALLDIR" Name="Trayslator">
                    <Component Id="TrayslatorFiles" DiskId="1" Guid="2cf58c8a-ad81-49e9-acbc-b1a3262acfc6" Win64="$(var.Win64Value)">
                        <!-- Files to be installed -->
                        <File Id="$(var.ExeNameUpper)" Name="$(var.ExeName)" Source="..\$(var.ExeName)" />
                        <File Id="LICENSE" Name="LICENSE" Source="..\LICENSE" />
                        <File Id="CONFIG" Name="google.ini" Source="..\google.ini" />
						<File Id="LIBCRYPTO"
							  Name="$(var.LibCryptoName)"
							  Source="$(var.OpenSslDir)\$(var.LibCryptoName)" />
						<File Id="LIBSSL"
							  Name="$(var.LibSslName)"
							  Source="$(var.OpenSslDir)\$(var.LibSslName)" />
                        <!-- Registry KeyPath to satisfy ICE38 -->
                        <RegistryValue Root="HKLM" Key="Software\Alexander Tverskoy\Trayslator" Name="InstallPath" Type="string" Value="[INSTALLDIR]" KeyPath="yes" />
                        <!-- Remove INSTALLDIR on uninstall -->
                        <RemoveFolder Id="RemoveINSTALLDIR" Directory="INSTALLDIR" On="uninstall" />
                    </Component>
                </Directory>
            </Directory>
            <Directory Id="DesktopFolder" />
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ProgramMenuDir" Name="Trayslator">
                    <Component Id="TrayslatorShortcuts" Guid="5B51614C-D5BE-4BDC-9EF3-97147A0DF68C" Permanent="yes">
                        <RegistryValue Root="HKCU" Key="Software\Alexander Tverskoy\Trayslator" Name="InstallPath" Type="string" Value="[INSTALLDIR]" />
                        <Shortcut Id="desktopShortcut" Directory="DesktopFolder" Name="Trayslator" WorkingDirectory="INSTALLDIR" Target="[INSTALLDIR]$(var.ExeName)" Icon="DesktopIcon.exe" IconIndex="0" />
                        <Shortcut Id="ExeShortcut" Directory="ProgramMenuDir" Name="Trayslator" Target="[INSTALLDIR]$(var.ExeName)" Icon="StartMenuIcon.exe" IconIndex="0" />
                    </Component>
                    <Component Id="StartMenuShortcuts" Guid="6A8B514C-D8BE-4ADC-9EF3-12347B0DF123">
                        <RemoveFolder Id="ProgramMenuDir" On="uninstall" />
                        <RegistryValue Root="HKCU" Key="Software\Alexander Tverskoy\Trayslator" Name="Product" Type="string" Value="[ProductName]" />
                        <Shortcut Id="UninstallProduct" Name="Uninstall" Description="Uninstalls the application" Target="[$(var.SystemFolder)]msiexec.exe" Arguments="/x [ProductCode]" />
                    </Component>
                </Directory>
            </Directory>
        </Directory>
        <Feature Id="DefaultFeature" Title="Main Feature" Level="1">
            <ComponentRef Id="TrayslatorFiles" />
            <ComponentRef Id="TrayslatorShortcuts" />
            <ComponentRef Id="StartMenuShortcuts" />
        </Feature>
        <UI>
            <UIRef Id="WixUI_Minimal" />
        </UI>
        <Icon Id="AppIcon" SourceFile="..\$(var.ExeName)" />
        <Icon Id="DesktopIcon.exe" SourceFile="..\$(var.ExeName)" />
        <Icon Id="StartMenuIcon.exe" SourceFile="..\$(var.ExeName)" />
    </Product>
</Wix>