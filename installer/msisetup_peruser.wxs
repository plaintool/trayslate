    <Product Id="*" Name="Trayslator" Language="1033" Version="1.0.0" Manufacturer="Alexander Tverskoy" UpgradeCode="45C75BC5-3DDC-453B-A7AB-7E2AE0D88699">
        <Package Description="Trayslator" Comments="Trayslator" Platform="x64" InstallerVersion="200" Compressed="yes" InstallScope="perUser" />
        <Property Id="MSIINSTALLPERUSER" Value="1" />
        <Property Id="MSIFASTINSTALL" Value="1" />
        <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />
        <Media Id="1" Cabinet="simple.cab" EmbedCab="yes" />
        <Upgrade Id="45C75BC5-3DDC-453B-A7AB-7E2AE0D88699">
            <UpgradeVersion Minimum="0.0.0" IncludeMinimum="yes" Maximum="1.0.0" IncludeMaximum="yes" Property="PREVIOUSFOUND" />
        </Upgrade>
        <InstallExecuteSequence>
            <RemoveExistingProducts After="InstallInitialize" />
        </InstallExecuteSequence>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="LocalAppDataFolder">
                <Directory Id="INSTALLDIR" Name="Trayslator">
                    <Component Id="TrayslatorFiles" DiskId="1" Guid="2cf58c8a-ad81-49e9-acbc-b1a3262acfc6" Win64="yes">
                        <!-- Files to be installed -->
                        <File Id="TRAYSLATOR.EXE" Name="trayslator.exe" Source="..\trayslator.exe" />
                        <File Id="LICENSE" Name="LICENSE" Source="..\LICENSE" />
                        <!-- Registry KeyPath to satisfy ICE38 -->
                        <RegistryValue Root="HKCU" Key="Software\Alexander Tverskoy\Trayslator" Name="InstallPath" Type="string" Value="[INSTALLDIR]" KeyPath="yes" />
                        <!-- Remove INSTALLDIR on uninstall -->
                        <RemoveFolder Id="RemoveINSTALLDIR" Directory="INSTALLDIR" On="uninstall" />
                    </Component>
                </Directory>
            </Directory>
            <Directory Id="DesktopFolder" />
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ProgramMenuDir" Name="Trayslator">
                    <Component Id="TrayslatorShortcuts" Guid="5B51614C-D5BE-4BDC-9EF3-97147A0DF68C" Permanent="yes">
                        <RegistryValue Root="HKCU" Key="Software\Alexander Tverskoy\Trayslator" Name="InstallPath" Type="string" Value="[INSTALLDIR]" />
                        <Shortcut Id="desktopShortcut" Directory="DesktopFolder" Name="Trayslator" WorkingDirectory="INSTALLDIR" Target="[INSTALLDIR]trayslator.exe" Icon="DesktopIcon.exe" IconIndex="0" />
                        <Shortcut Id="ExeShortcut" Directory="ProgramMenuDir" Name="Trayslator" Target="[INSTALLDIR]trayslator.exe" Icon="StartMenuIcon.exe" IconIndex="0" />
                    </Component>
                    <Component Id="StartMenuShortcuts" Guid="6A8B514C-D8BE-4ADC-9EF3-12347B0DF123">
                        <RemoveFolder Id="ProgramMenuDir" On="uninstall" />
                        <RegistryValue Root="HKCU" Key="Software\Alexander Tverskoy\Trayslator" Name="Product" Type="string" Value="[ProductName]" />
                        <Shortcut Id="UninstallProduct" Name="Uninstall" Description="Uninstalls the application" Target="[System64Folder]msiexec.exe" Arguments="/x [ProductCode]" />
                    </Component>
                </Directory>
            </Directory>
        </Directory>
        <Component Id="TrayslatorRegistry" Directory="INSTALLDIR" Guid="4A5B87A9-6F9F-4AD4-A9AB-4D3D9DAB4FC8" Win64="yes">
            <!-- Add .tsk extension association -->
            <RegistryKey Root="HKCU" Key="Software\Classes\.tsk" Action="createAndRemoveOnUninstall">
                <RegistryValue Type="string" Value="trayslator" KeyPath="yes" />
                <!-- Add "New → TSK File" to context menu -->
                <RegistryKey Key="ShellNew" Action="createAndRemoveOnUninstall">
                    <RegistryValue Name="NullFile" Type="string" Value="" />
                </RegistryKey>
            </RegistryKey>
            <!-- Define the trayslator file association -->
            <RegistryKey Root="HKCU" Key="Software\Classes\trayslator" Action="createAndRemoveOnUninstall">
                <RegistryValue Type="string" Value="Trayslator Tasks" />
                <RegistryKey Key="DefaultIcon">
                    <RegistryValue Type="string" Value="[INSTALLDIR]trayslator.exe,1" />
                </RegistryKey>
                <RegistryKey Key="shell\open\command">
                    <RegistryValue Type="string" Value="&quot;[INSTALLDIR]trayslator.exe&quot; &quot;%1&quot;" />
                </RegistryKey>
            </RegistryKey>
            <!-- Add application association in the registry -->
            <RegistryKey Root="HKCU" Key="Software\Classes\Applications\trayslator.exe" Action="createAndRemoveOnUninstall">
                <RegistryKey Key="shell\open\command">
                    <RegistryValue Type="string" Value="&quot;[INSTALLDIR]trayslator.exe&quot; &quot;%1&quot;" />
                </RegistryKey>
            </RegistryKey>
        </Component>
        <Feature Id="DefaultFeature" Title="Main Feature" Level="1">
            <ComponentRef Id="TrayslatorFiles" />
            <ComponentRef Id="TrayslatorShortcuts" />
            <ComponentRef Id="StartMenuShortcuts" />
            <ComponentRef Id="TrayslatorRegistry" />
