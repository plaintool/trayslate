#: tformconfigtrayslate.labelparemeters.caption
msgctxt "tformconfigtrayslate.labelparemeters.caption"
msgid "Use parameters: {text} – input text, {source} – source language, {target} – target language. Prefix the name with ! for lowercase or ^ for uppercase value. Also supported {timestamp}, {rand}. Use {parameter} from the parameters page."
msgstr "Use parâmetros: {text} – texto de entrada, {source} – idioma de origem, {target} – idioma de destino. Prefixe o nome com ! para minúsculas ou ^ para maiúsculas. Também suportados {timestamp}, {rand}. Use {parameter} da página de parâmetros."

